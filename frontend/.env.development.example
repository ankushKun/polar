# Vite dev - leave VITE_API_BASE unset so requests use the /api proxy → worker :8787.
# Copy to .env.development (optional; Vite uses the proxy by default when unset).
#
# If you set VITE_API_BASE directly, worker/.dev.vars FRONTEND_URL must match this origin:
# VITE_API_BASE=http://127.0.0.1:8787/api

# Local UI preview without GitHub OAuth (requires worker/.dev.vars DEV_AUTH_BYPASS=true)
VITE_DEV_AUTH_BYPASS=true

# Populate Dashboard/ProjectDetail with mock data instead of empty local D1
VITE_DEV_MOCK_DATA=true
