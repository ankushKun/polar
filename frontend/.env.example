# Frontend environment files (see also .env.development.example and .env.production.example)
#
# Local dev:     .env.development  — use Vite /api proxy (leave VITE_API_BASE unset)
# Worker deploy: .env.production   — VITE_API_BASE=/api (set automatically by npm run deploy)
# Walrus deploy (polar.wal.app):
#   VITE_API_BASE=https://your-org-worker.workers.dev/api
#   VITE_PORTAL_SUBDOMAIN_BASE=polar.ankush.one
#
# Worker secrets live in worker/.dev.vars (copy from worker/.dev.vars.example).
